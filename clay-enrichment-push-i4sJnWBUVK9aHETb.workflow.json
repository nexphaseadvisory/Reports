      "position": [
        800,
        100
      ],
      "parameters": {
        "method": "POST",
        "url": "https://PLACEHOLDER-REPLACE-WITH-CLAY-INGESTION-WEBHOOK",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {}
      }
    },
