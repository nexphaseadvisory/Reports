      "name": "Build Clay Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        540,
        100
      ],
      "parameters": {
        "jsCode": "// Build the Clay ingestion payload per Needs-Clay lead.\n// clay_record_id = Airtable record id -> Clay echoes it back so the callback can match.\nreturn $input.all().map(item => {\n  const f = item.json.fields || item.json;\n  return { json: {\n    clay_record_id: item.json.id,\n    company:        f['Company'] || '',\n    contact_name:   f['Contact Name'] || '',\n    linkedin_url:   f['LinkedIn URL'] || '',\n    title:          f['Title'] || '',\n    signal_hook:    f['Signal Hook'] || ''\n  }};\n});"
      }
    },
