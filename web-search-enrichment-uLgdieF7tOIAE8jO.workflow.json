        {
            "parameters": {
                "method": "POST",
                "url": "https://api.anthropic.com/v1/messages",
                "authentication": "genericCredentialType",
                "genericAuthType": "httpHeaderAuth",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "anthropic-version",
                            "value": "2023-06-01"
                        },
                        {
                            "name": "content-type",
                            "value": "application/json"
                        }
                    ]
                },
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={{ JSON.stringify({model: 'claude-sonnet-4-6',max_tokens: 1024,tools: [{ type: 'web_search_20250305', name: 'web_search', max_uses: 5 }],system: 'You are a B2B contact researcher. You find the single best senior decision-maker at a company for energy/power procurement, interconnection, or development outreach, plus their personal LinkedIn profile. Return ONLY one JSON object as your final message \u2014 no prose, no markdown fences. Schema: {\\\"found\\\": boolean, \\\"contact_name\\\": string, \\\"linkedin_url\\\": string, \\\"title\\\": string}. linkedin_url MUST be a personal profile of the form https://www.linkedin.com/in/... . If you cannot find a real named person with a real personal LinkedIn profile URL, return {\\\"found\\\": false, \\\"contact_name\\\": \\\"\\\", \\\"linkedin_url\\\": \\\"\\\", \\\"title\\\": \\\"\\\"}. Never fabricate a URL.',messages: [{ role: 'user', content: 'Find the best outreach contact at the company \\\"' + $json.company + '\\\" for power/energy procurement, interconnection, or development. ' + ($json.title_hint ? ('Prefer someone whose role matches: \\\"' + $json.title_hint + '\\\". ') : '') + 'Run this web search to find them: ' + $json.query + ' . Then return the JSON object only.' }]}) }}",
                "options": {
                    "batching": {
                        "batch": {
                            "batchSize": 1
                        }
                    },
                    "timeout": 90000
                }
            },
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                500,
                160
            ],
            "name": "Claude Web Search",
            "credentials": {
                "httpHeaderAuth": {
                    "id": "FJA7PZjCaMHaj0Ir",
                    "name": "Header Auth Claude API"
                }
            },
            "onError": "continueRegularOutput",
            "retryOnFail": true,
            "maxTries": 2,
            "waitBetweenTries": 3000,
            "id": "70340adf-68b2-41c1-b858-9fc605c6107d"
        },
        {
            "parameters": {
                "jsCode": "\nconst resp = $json;\nconst src = $('Build Search Input').item.json;\nlet found = false, name = '', url = '', title = '';\ntry {\n  if (resp && Array.isArray(resp.content)) {\n    const text = resp.content.filter(b => b.type === 'text').map(b => b.text).join('\\n');\n    const m = text.match(/\\{[\\s\\S]*\\}/);\n    if (m) {\n      const parsed = JSON.parse(m[0]);\n      name = String(parsed.contact_name || '').trim();\n      url = String(parsed.linkedin_url || '').trim();\n      title = String(parsed.title || '').trim();\n      found = parsed.found === true && name !== '' && /linkedin\\.com\\/in\\//i.test(url);\n    }\n  }\n} catch (e) { found = false; }\nreturn { json: {\n  record_id: src.record_id,\n  company: src.company,\n  success: found,\n  contact_name: name,\n  linkedin_url: url,\n  title: (title || src.title_hint)\n}};\n",
                "mode": "runOnceForEachItem"
            },
