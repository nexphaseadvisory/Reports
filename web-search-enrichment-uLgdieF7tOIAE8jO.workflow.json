        {
            "parameters": {
                "jsCode": "\nconst out = [];\nfor (const item of $input.all()) {\n  const j = item.json;\n  const company = String(j['Company'] || '').trim();\n  const titleHint = String(j['Title'] || '').trim();\n  const existingUrl = String(j['LinkedIn URL'] || '').trim();\n  const existingName = String(j['Contact Name'] || '').trim();\n  const hasLinkedin = /linkedin\\.com/i.test(existingUrl);\n  const keywords = titleHint || 'VP OR Director power OR energy OR interconnection OR origination';\n  out.push({ json: {\n    record_id: j.id,\n    company: company,\n    title_hint: titleHint,\n    existing_url: existingUrl,\n    existing_name: existingName,\n    has_linkedin: hasLinkedin,\n    query: company + ' ' + keywords + ' site:linkedin.com'\n  }});\n}\nreturn out;\n"
            },
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                60,
