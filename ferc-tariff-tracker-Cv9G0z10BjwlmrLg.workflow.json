            "parameters": {
                "jsCode": "// Failure branch: FERC ingest failed. Emit a Daily Brief alert payload.\nconst err = $input.first().json;\nreturn [{ json: {\n  alert: 'FERC_INGEST_FAILED',\n  message: 'FERC eLibrary tariff ingest failed - check manually. The eLibrary backend is unofficial and may have changed shape or rate-limited.',\n  httpCode: err.statusCode || err.code || 'unknown',\n  ts: new Date().toISOString()\n} }];"
            },
