            {
                "parameters": {
                    "jsCode": "const toISO = (s) => { if (!s) return ''; const m = String(s).match(/^(\\d{1,2})\\/(\\d{1,2})\\/(\\d{4})$/); return m ? `${m[3]}-${m[1].padStart(2,'0')}-${m[2].padStart(2,'0')}` : String(s); };\nconst claude = $input.all();\nconst filings = $('Build Claude Body').all();\nconst out = [];\nfor (let i = 0; i < claude.length; i++) {\n  const r = claude[i].json;\n  const f = (filings[i] && filings[i].json) || {};\n  let parsed = null;\n  try {\n    const txt = (r.content || []).filter(b => b.type === 'text').map(b => b.text).join('').replace(/```json|```/g, '').trim();\n    parsed = JSON.parse(txt);\n  } catch (e) { continue; }\n  if (!parsed || typeof parsed.score !== 'number' || parsed.score <= 2) continue;\n  const aff = Array.isArray(f.affiliations) ? (f.affiliations.find(a => a.afType === 'author') || {}) : {};\n  out.push({ json: {\n    docketNo: f.docketNo, accessionNumber: f.accessionNumber, description: f.description,\n    category: f.category, filedDate: toISO(f.filedDate), issuedDate: toISO(f.issuedDate), eLibraryUrl: f.eLibraryUrl,\n    filer: aff.affiliation || '', score: parsed.score, iso: parsed.iso, theme: parsed.theme, one_line: parsed.one_line\n  } });\n}\nreturn out;"
