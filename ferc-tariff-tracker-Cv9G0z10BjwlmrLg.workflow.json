        {
            "parameters": {
                "jsCode": "// Build rolling 2-day filed-date window (yesterday 00:00 -> today 23:59 UTC).\n// FERC posts on a ~1 business day lag; 2-day window absorbs weekend/holiday catch-up.\nconst now = new Date();\nconst end = new Date(now);\nend.setUTCHours(23, 59, 59, 0);\nconst start = new Date(now);\nstart.setUTCDate(start.getUTCDate() - 1);\nstart.setUTCHours(0, 0, 0, 0);\n\nconst body = {\n  docketSearches: [],\n  searchText: 'interconnection OR \"large load\" OR co-location OR colocation OR \"data center\" OR \"queue reform\" OR \"cost allocation\" OR \"generator interconnection\" OR \"surplus interconnection service\" OR \"network upgrade\" OR \"affected system\" OR \"energy storage\"',\n  searchFullText: true,\n  searchDescription: true,\n  allDates: false,\n  dateSearches: [\n    { dateType: 'filed_date', startDate: start.toISOString(), endDate: end.toISOString() }\n  ],\n  classTypes: [],\n  affiliations: [],\n  availability: ['p'],\n  categories: ['Submittal', 'Issuance'],\n  libraries: ['Electric'],\n  eFiling: false,\n  sortBy: '',\n  groupBy: 'NONE',\n  resultsPerPage: 100,\n  curPage: 1,\n  idolResultID: '',\n  accessionNumber: null\n};\n\nreturn [{ json: { body, windowStart: start.toISOString(), windowEnd: end.toISOString() } }];"
            },
            "id": "db7c83a9-9a8b-471e-a9ae-7158caa2468c",
            "name": "Build Search Body",
            "type": "n8n-nodes-base.code",
