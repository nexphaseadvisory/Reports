        {
            "parameters": {
                "jsCode": "// Keyword pre-filter: cheap regex gate before spending Claude tokens.\nconst KEYWORDS = [\n  'interconnection', 'large load', 'co-location', 'colocation', 'data center',\n  'queue reform', 'cost allocation', 'generator interconnection',\n  'surplus interconnection service', 'gia', 'lgia', 'affected system',\n  'network upgrade', 'point of interconnection', 'energy storage'\n];\nconst rx = new RegExp(KEYWORDS.map(k => k.replace(/[.*+?^${}()|[\\]\\\\]/g, '\\\\$&')).join('|'), 'i');\n\nconst resp = $input.first().json;\nconst hits = Array.isArray(resp.searchHits) ? resp.searchHits : [];\nconst out = [];\nfor (const h of hits) {\n  const hay = `${h.description || ''} ${(h.docketNumbers || []).join(' ')}`;\n  if (!rx.test(hay)) continue;\n  const acc = h.acesssionNumber || h.accessionNumber || ''; // source misspells this key\n  out.push({\n    json: {\n      docketNumbers: h.docketNumbers || [],\n      docketNo: (h.docketNumbers || [])[0] || '',\n      accessionNumber: acc,\n      description: h.description || '',\n      category: h.category || '',\n      filedDate: h.filedDate || '',\n      issuedDate: h.issuedDate || '',\n      affiliations: h.affiliations || [],\n      eLibraryUrl: acc ? `https://elibrary.ferc.gov/eLibrary/filelist?accession_number=${acc}` : ''\n    }\n  });\n}\nreturn out;"
            },
