                    "jsCode": "const SYS = 'You score FERC electric tariff filings for relevance to The Interconnect, a weekly publication read by renewable/storage developers, IPPs, and data-center power buyers. Score 1-5 for how much this filing matters to that audience. 5 = major queue reform, large-load/co-location policy, or cost-allocation shift with broad market impact. 1 = routine single-party rate tweak. Respond with ONLY a JSON object, no preamble, no markdown: {\"score\":1-5,\"iso\":\"PJM|MISO|SPP|CAISO|NYISO|ISO-NE|multi|n/a\",\"theme\":\"queue reform|large load|cost allocation|colocation|other\",\"one_line\":\"<=20 words plain English\"}';\nconst out = [];\nfor (const it of $input.all()) {\n  const f = it.json;\n  const userMsg = `Docket: ${f.docketNo}\\nCategory: ${f.category}\\nFiled: ${f.filedDate}\\nDescription: ${f.description}`;\n  out.push({ json: { ...f, _claudeBody: { model: 'claude-sonnet-4-6', max_tokens: 300, system: SYS, messages: [{ role: 'user', content: userMsg }] } } });\n}\nreturn out;"
